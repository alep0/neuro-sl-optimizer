# =============================================================================
# .gitignore — neuro-sl-optimizer
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.installed.cfg
*.egg-link
MANIFEST

# ---------------------------------------------------------------------------
# C++ build artefacts
# ---------------------------------------------------------------------------
*.o
*.a
*.dll
*.dylib
*.lib
*.exp
stuart_landau_simulator*.so
stuart_landau_simulator*.pyd

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env

# ---------------------------------------------------------------------------
# Conda
# ---------------------------------------------------------------------------
.conda/

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# ---------------------------------------------------------------------------
# Project-specific generated files
# ---------------------------------------------------------------------------
logs/*.log
results/
!results/.gitkeep

# Data files — track only structure, not content
data/raw/*.txt
data/processed/*.json
data/processed/*.npy
data/external/

# Keep placeholder files so directories are tracked by git
!data/raw/.gitkeep
!data/processed/.gitkeep
!logs/.gitkeep
!results/.gitkeep

# Carpetas
#git rm -r --cached old_versions
old_versions*/
